flowchart TB
    User([User · Browser])

    subgraph Vercel["Vercel — Next.js 16 · App Router · Turbopack"]
        UI["v0 UI · React 19<br/>React Flow graph + AnalysisPanel<br/>Playground (stateless)"]
        SA["Server Actions<br/>analyze.ts (estate · streamed)<br/>playground.ts (stateless)"]
        RH["Route Handler<br/>/api/estate/[id]/graph"]
        OIDC["@vercel/functions/oidc"]
    end

    subgraph Anthropic["Anthropic"]
        SDK["Anthropic TS SDK · streaming"]
        Sonnet["Claude Sonnet 4.6<br/>analysis · temp 0"]
        Haiku["Claude Haiku 4.5<br/>triage · temp 0"]
    end

    subgraph AWS["AWS"]
        IAM["IAM Role<br/>(Vercel Marketplace OIDC)"]
        Signer["@aws-sdk/rds-signer<br/>IAM token · per connection"]
        subgraph DB["Amazon Aurora PostgreSQL Serverless v2 · PG16"]
            Drizzle["Drizzle ORM<br/>WITH RECURSIVE + cycle guard<br/>(lib/db/lineage.ts)"]
            Tables[("estate · program · copybook<br/>data_element · analysis_run<br/>business_rule · ticket · dependency")]
        end
    end

    User --> UI
    UI --> SA
    UI --> RH
    SA --> SDK
    SDK --> Sonnet
    SDK --> Haiku
    SA --> Drizzle
    RH --> Drizzle
    OIDC --> IAM --> Signer --> Drizzle
    Drizzle --> Tables
    Sonnet -. JSON details .-> SA
    SA -. summary derived in code .-> Drizzle
