# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── AWS / Vercel OIDC (auto-injected on Vercel; configure via Vercel dashboard) ─
AWS_ACCOUNT_ID=<your-aws-account-id>
AWS_REGION=us-east-1
AWS_RESOURCE_ARN=arn:aws:rds:us-east-1:<account-id>:cluster:<cluster-name>
AWS_ROLE_ARN=arn:aws:iam::<account-id>:role/Vercel/access-<cluster-name>

# ── Aurora PostgreSQL (no password — auth is via IAM token minted from OIDC) ───
PGHOST=<cluster-name>.cluster-<suffix>.us-east-1.rds.amazonaws.com
PGUSER=postgres
PGDATABASE=postgres
PGPORT=5432
PGSSLMODE=require

# ── Local integration tests only (testcontainers + Docker Desktop on macOS) ──
# Copy these into .env.local and replace <you> with your macOS username.
# DOCKER_HOST=unix:///Users/<you>/.docker/run/docker.sock
# TESTCONTAINERS_DOCKER_SOCKET_OVERRIDE=/Users/<you>/.docker/run/docker.sock